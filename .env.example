# ════════════════════════════════════════════════════════════════
# Orbit — Environment Variables
# Copy to .env and fill in values before starting.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# ── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://orbit:orbit_pass@db:5432/orbit

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Webex ──────────────────────────────────────────────────────
# Set via Settings UI after first login — stored encrypted in AppConfig
# WEBEX_ACCESS_TOKEN=
# WEBEX_ORG_ID=

# ── ServiceNow ─────────────────────────────────────────────────
# Set via Settings UI after first login — stored encrypted in AppConfig
# SNOW_INSTANCE=https://yourcompany.service-now.com
# SNOW_USERNAME=
# SNOW_PASSWORD=
# SNOW_WEBHOOK_SECRET=

# ── SMTP ───────────────────────────────────────────────────────
# Set via Settings UI after first login — stored encrypted in AppConfig
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SENDER_EMAIL=orbit@yourcompany.com
# SMTP_SENDER_NAME=Orbit

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_STDOUT=true
# LOG_FILE=/var/log/orbit/orbit.log

# ── Gunicorn ───────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_TIMEOUT=120
